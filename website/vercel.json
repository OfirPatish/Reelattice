{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/download", "destination": "/download.html" },
    { "source": "/((?!download\\.html|assets|icons|og-image\\.svg|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
